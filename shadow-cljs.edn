{:source-paths ["src"]

 :dependencies [[org.clojure/clojurescript "1.10.773"]
                [org.clojure/clojure "1.10.1"]]

 :builds
 {:app
  {:target :browser
   :output-dir "public/js"
   :asset-path "/js"
   :modules {:main {:entries [lispmind.core]}}
   :compiler-options {:optimizations :simple}
   :devtools {:after-load lispmind.core/init
              :preloads []
              :http-root "public"
              :http-port 8080}}}}
